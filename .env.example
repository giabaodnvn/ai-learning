# App
APP_NAME=ai_learning
APP_PORT=3003
FRONTEND_PORT=3000
RAILS_ENV=development

# Database (MySQL)
DB_HOST=db
DB_PORT=3308
DB_USERNAME=root
DB_PASSWORD=password
DB_NAME=ai_learning_development
DATABASE_URL=mysql2://root:password@db/ai_learning_development

# Redis & Sidekiq
REDIS_PORT=6380
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY_BASE=        # rails secret
DEVISE_JWT_SECRET_KEY=  # rails secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI (Gemini API — backend only, never expose to frontend)
GEMINI_API_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3003
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=        # rails secret
