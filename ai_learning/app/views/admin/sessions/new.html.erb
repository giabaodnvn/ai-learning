<% content_for :title, "Đăng nhập" %>

<div class="min-h-screen bg-gray-900 flex items-center justify-center px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <span class="text-3xl">🎌</span>
      <h1 class="mt-3 text-2xl font-bold text-white">AI Learning</h1>
      <p class="text-gray-400 text-sm mt-1">Admin Panel</p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl p-8">
      <% if flash.now[:alert] %>
        <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
          <%= flash.now[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_login_path, method: :post, local: true, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <%= f.email_field :email,
                placeholder: "admin@example.com",
                required: true,
                class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu</label>
          <%= f.password_field :password,
                placeholder: "••••••••",
                required: true,
                class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>

        <%= f.submit "Đăng nhập",
              class: "w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition cursor-pointer" %>
      <% end %>
    </div>
    <p class="text-center text-xs text-gray-500 mt-4">Chỉ dành cho tài khoản có quyền Admin</p>
  </div>
</div>
