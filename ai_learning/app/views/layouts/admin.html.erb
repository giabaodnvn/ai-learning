<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= content_for?(:title) ? yield(:title) + " — " : "" %>AI Learning Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { colors: { brand: { 50:'#eff6ff',500:'#3b82f6',600:'#2563eb',700:'#1d4ed8',900:'#1e3a8a' } } } }
    }
  </script>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen">

<% if defined?(current_admin) && current_admin %>
<%# ── Sidebar ──────────────────────────────────────────────────────────── %>
<div class="flex min-h-screen">
  <aside class="w-56 bg-gray-900 text-gray-100 flex flex-col shrink-0">
    <div class="px-5 py-5 border-b border-gray-700">
      <span class="text-sm font-bold tracking-widest text-brand-500 uppercase">AI Learning</span>
      <p class="text-xs text-gray-400 mt-0.5">Admin Panel</p>
    </div>

    <nav class="flex-1 py-4 space-y-0.5 px-2">
      <%= nav_link "🏠  Dashboard",    admin_root_path %>
      <%= nav_link "👥  Người dùng",   admin_users_path %>
      <%= nav_link "💰  Chi phí AI",   admin_ai_costs_path %>
      <div class="my-3 border-t border-gray-700"></div>
      <a href="/sidekiq" target="_blank"
         class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-gray-400 hover:bg-gray-800 hover:text-white transition">
        ⚙️  Sidekiq Jobs
      </a>
    </nav>

    <div class="px-4 py-4 border-t border-gray-700">
      <p class="text-xs text-gray-400 truncate"><%= current_admin.email %></p>
      <%= button_to "Đăng xuất", admin_logout_path, method: :delete,
            class: "mt-2 w-full text-xs text-gray-400 hover:text-red-400 text-left transition" %>
    </div>
  </aside>

  <%# ── Main content ─────────────────────────────────────────────────── %>
  <div class="flex-1 flex flex-col min-w-0">
    <header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between">
      <h1 class="text-base font-semibold text-gray-700"><%= yield(:page_title) || "Admin" %></h1>
      <span class="text-xs text-gray-400"><%= Date.current.strftime("%d/%m/%Y") %></span>
    </header>

    <%# Flash messages %>
    <% if flash[:notice] %>
      <div class="mx-6 mt-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700 flex items-center gap-2">
        ✓ <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mx-6 mt-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700 flex items-center gap-2">
        ⚠ <%= flash[:alert] %>
      </div>
    <% end %>

    <main class="flex-1 p-6">
      <%= yield %>
    </main>
  </div>
</div>

<% else %>
<%# ── No sidebar (login page) ────────────────────────────────────────── %>
<% if flash[:notice] %>
  <div class="fixed top-4 left-1/2 -translate-x-1/2 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-700 shadow">
    ✓ <%= flash[:notice] %>
  </div>
<% end %>
<% if flash[:alert] %>
  <div class="fixed top-4 left-1/2 -translate-x-1/2 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700 shadow">
    ⚠ <%= flash[:alert] %>
  </div>
<% end %>
<main><%= yield %></main>
<% end %>

</body>
</html>
