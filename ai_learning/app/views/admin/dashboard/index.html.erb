<% content_for :page_title, "Dashboard" %>

<%# ── Stat cards ──────────────────────────────────────────────────────────── %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%= stat_card "👥 Tổng user",       @stats[:total_users],   "blue" %>
  <%= stat_card "📈 Hoạt động hôm nay", @stats[:active_today], "green" %>
  <%= stat_card "⭐ VIP user",         @stats[:vip_users],    "yellow" %>
  <%= stat_card "🚫 Bị khóa",          @stats[:blocked_users],"red" %>
</div>

<%# ── AI usage today ──────────────────────────────────────────────────────── %>
<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="col-span-3 lg:col-span-1 bg-white rounded-xl border border-gray-200 p-5">
    <h2 class="text-sm font-semibold text-gray-600 mb-4">🤖 AI hôm nay</h2>
    <dl class="space-y-3">
      <div class="flex justify-between text-sm">
        <dt class="text-gray-500">Requests</dt>
        <dd class="font-semibold"><%= @ai_stats[:requests_today] %></dd>
      </div>
      <div class="flex justify-between text-sm">
        <dt class="text-gray-500">Tokens</dt>
        <dd class="font-semibold"><%= number_with_delimiter(@ai_stats[:tokens_today]) %></dd>
      </div>
      <div class="flex justify-between text-sm">
        <dt class="text-gray-500">Chi phí ước tính</dt>
        <dd class="font-semibold text-green-600">$<%= @ai_stats[:cost_today] %></dd>
      </div>
    </dl>
    <div class="mt-4">
      <%= link_to "Xem chi tiết →", admin_ai_costs_path, class: "text-xs text-blue-600 hover:underline" %>
    </div>
  </div>

  <%# ── Sign-up chart (14 days) ────────────────────────────────────────── %>
  <div class="col-span-3 lg:col-span-2 bg-white rounded-xl border border-gray-200 p-5">
    <h2 class="text-sm font-semibold text-gray-600 mb-4">📊 Đăng ký 14 ngày qua</h2>
    <% max_count = [@daily_signups.values.max.to_i, 1].max %>
    <div class="flex items-end gap-1 h-24">
      <% (13.downto(0)).each do |i| %>
        <% date = (Date.current - i).to_s %>
        <% count = @daily_signups[date].to_i %>
        <div class="flex-1 flex flex-col items-center gap-1 group relative">
          <div class="w-full bg-blue-500 rounded-t transition-all"
               style="height: <%= [(count.to_f / max_count * 80).round, 2].max %>px;"
               title="<%= date %>: <%= count %> users"></div>
          <span class="text-gray-300 text-xs hidden group-hover:block absolute bottom-0 bg-gray-800 text-white px-1 rounded text-center">
            <%= count %>
          </span>
        </div>
      <% end %>
    </div>
    <div class="flex justify-between mt-1 text-xs text-gray-400">
      <span><%= (Date.current - 13).strftime("%d/%m") %></span>
      <span><%= Date.current.strftime("%d/%m") %></span>
    </div>
  </div>
</div>

<%# ── Recent users ─────────────────────────────────────────────────────────── %>
<div class="bg-white rounded-xl border border-gray-200">
  <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700">Người dùng mới nhất</h2>
    <%= link_to "Xem tất cả →", admin_users_path, class: "text-xs text-blue-600 hover:underline" %>
  </div>
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-xs text-gray-500 uppercase">
      <tr>
        <th class="px-5 py-3 text-left">Email</th>
        <th class="px-5 py-3 text-left">Tên</th>
        <th class="px-5 py-3 text-left">Level</th>
        <th class="px-5 py-3 text-left">Role</th>
        <th class="px-5 py-3 text-left">VIP</th>
        <th class="px-5 py-3 text-left">Đăng ký</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @recent_users.each do |u| %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-5 py-3">
            <%= link_to u.email, admin_user_path(u), class: "text-blue-600 hover:underline font-medium" %>
          </td>
          <td class="px-5 py-3 text-gray-600"><%= u.name.presence || "—" %></td>
          <td class="px-5 py-3"><span class="font-mono uppercase text-xs bg-gray-100 px-2 py-0.5 rounded"><%= u.jlpt_level %></span></td>
          <td class="px-5 py-3"><%= role_badge(u.role) %></td>
          <td class="px-5 py-3"><%= vip_badge(u.vip_level) %></td>
          <td class="px-5 py-3 text-gray-400 text-xs"><%= u.created_at.strftime("%d/%m/%Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% content_for :extra_helpers do %>
<script>
  // Tooltip on hover for bar chart
</script>
<% end %>
